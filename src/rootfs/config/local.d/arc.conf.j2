# ARC signing

path = "/etc/rspamd/arc/$selector.key";
selector_map = "/etc/rspamd/arc_selectors.map";
selector = {{ environ('RSPAMD_ARC_DEFAULT_SELECTOR') }}

sign_authenticated = true;
sign_local = true;
sign_inbound = true;
use_domain = "header";
use_auth_results = true;
allow_headers_fallback = true;
